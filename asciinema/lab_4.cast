[15.332884, "o", "###############################################################################################################\r\n- Checking Agent Card payload deployed inside the cluster (app.py):\r\n"]
[15.400707, "o", "from http.server import BaseHTTPRequestHandler, HTTPServer\r\nimport json\r\n\r\nclass A2AHandler(BaseHTTPRequestHandler):\r\n    def do_GET(self):\r\n        if self.path == '/.well-known/agent-card.json':\r\n            self.send_response(200)\r\n            self.send_header('Content-type', 'application/json')\r\n            self.end_headers()\r\n            card = {\r\n                \"name\": \"Custom-Lab4-Agent\",\r\n                \"description\": \"A2A Agent created for Lab 4\",\r\n                \"icon_url\": \"https://a2a-protocol.org/icon.png\",\r\n                \"version\": \"1.0.0\",\r\n                \"supported_interfaces\": [\r\n                    {\"url\": \"http://a2a-custom-agent.kagent.svc.cluster.local:8080/protocol\", \"protocol\": \"HTTP\"}\r\n                ],\r\n                \"capabilities\": {\"streaming\": False},\r\n                \"default_input_modes\": [\"text/plain\"],\r\n                \"default_output_modes\": [\"text/plain\"],\r\n                \"skills\": [\r\n                    {\r\n                        \"id\": \"echo-skill\",\r\n              "]
[15.400858, "o", "          \"name\": \"Echo Skill\",\r\n                        \"description\": \"Echoes back the input\",\r\n                        \"input_modes\": [\"text/plain\"],\r\n                        \"output_modes\": [\"text/plain\"]\r\n                    }\r\n                ]\r\n            }\r\n"]
